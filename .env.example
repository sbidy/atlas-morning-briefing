# Copy to .env and fill in your values:
#   cp .env.example .env

FINNHUB_API_KEY=your_finnhub_key
BRAVE_API_KEY=your_brave_search_key
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=

# AWS (optional, only needed if bedrock.enabled: true in config.yaml)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1

# Optional: override the heavy-tier model with a full inference profile ARN
# BEDROCK_INFERENCE_PROFILE_ARN=arn:aws:bedrock:eu-central-1:123456789012:inference-profile/eu.anthropic.claude-opus-4-6-v1
