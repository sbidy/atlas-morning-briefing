# Atlas Morning Briefing Configuration
# Copy this file to config.yaml and customize for your needs:
#   cp config.yaml.example config.yaml

# Topics to scan on arxiv
arxiv_topics:
  - "Agentic AI"
  - "Agent Evaluation"
  - "Multi-Agent Systems"
  - "Tool Use LLM"
  - "VLA Robotics"
  - "World Models"
  - "NKI Trainium"
  - "Physical AI Embodied"
  - "Autonomous Driving End-to-End"
  - "Reinforcement Learning Code Generation"
  - "LLM Inference Optimization"
  - "AI Safety Alignment"

# RSS feeds to monitor
blog_feeds:
  - name: "AWS ML Blog"
    url: "https://aws.amazon.com/blogs/machine-learning/feed/"
  - name: "Anthropic"
    url: "https://www.anthropic.com/rss.xml"
  - name: "Karpathy"
    url: "https://karpathy.github.io/feed.xml"
  - name: "OpenAI"
    url: "https://openai.com/blog/rss.xml"
  - name: "Eugene Yan"
    url: "https://eugeneyan.com/rss/"
  - name: "Chip Huyen"
    url: "https://huyenchip.com/feed.xml"
  - name: "Interconnects"
    url: "https://www.interconnects.ai/feed"
  - name: "Lilian Weng"
    url: "https://lilianweng.github.io/index.xml"
  - name: "Sebastian Raschka"
    url: "https://magazine.sebastianraschka.com/feed"
  - name: "The Gradient"
    url: "https://thegradient.pub/rss/"
  - name: "BAIR"
    url: "https://bair.berkeley.edu/blog/feed.xml"
  - name: "DeepMind"
    url: "https://deepmind.google/blog/rss.xml"
  - name: "Hugging Face"
    url: "https://huggingface.co/blog/feed.xml"
  - name: "Google AI Blog"
    url: "https://blog.research.google/feeds/posts/default?alt=rss"
  - name: "Meta AI"
    url: "https://ai.meta.com/blog/rss/"
  - name: "Microsoft Research"
    url: "https://www.microsoft.com/en-us/research/feed/"
  - name: "NVIDIA AI"
    url: "https://blogs.nvidia.com/feed/"
  - name: "MIT News AI"
    url: "https://news.mit.edu/topic/artificial-intelligence2-rss.xml"
  - name: "The Verge AI"
    url: "https://www.theverge.com/rss/ai-artificial-intelligence/index.xml"
  - name: "TechCrunch AI"
    url: "https://techcrunch.com/category/artificial-intelligence/feed/"
  - name: "Ars Technica AI"
    url: "https://feeds.arstechnica.com/arstechnica/technology-lab"
  - name: "VentureBeat AI"
    url: "https://venturebeat.com/category/ai/feed/"
  - name: "MIT Technology Review"
    url: "https://www.technologyreview.com/feed/"

# Interest profile for relevance filtering
interest_profile:
  - topic: "Agentic AI"
    weight: 1.0
  - topic: "Trainium NKI Neuron SDK"
    weight: 0.9
  - topic: "VLA Robotics Physical AI"
    weight: 0.8
  - topic: "Multi-Agent Systems"
    weight: 0.8
  - topic: "Enterprise AI adoption"
    weight: 0.7
  - topic: "LLM inference optimization"
    weight: 0.7
  - topic: "Autonomous driving"
    weight: 0.6
  - topic: "AI safety alignment"
    weight: 0.5

# Stock watchlist (Finnhub API)
stocks:
  - AMZN
  - GOOGL
  - TSLA
  - SPY

# News search queries (Brave Search API)
news_queries:
  - "AI artificial intelligence breakthrough"
  - "LLM agent framework"
  - "autonomous driving AI"
  - "OpenAI GPT model release"
  - "Anthropic Claude"
  - "Google DeepMind Gemini"
  - "AI regulation policy"
  - "semiconductor chip Nvidia"
  - "robotics embodied AI"

# Paper scoring weights
paper_scoring:
  has_code: 7
  topic_match: 3
  recency: 2
  citation_count: 1

# Reproduction feasibility gate (applied by intelligence layer)
# Papers scoring below repro_min_score/25 are dropped from top picks
repro_min_score: 12

# Delivery settings
kindle_email: "YOUR_NAME@kindle.com"
sender_email: "your-sender@gmail.com"
output_format: "kindle"

# Email distribution list (receives rich HTML briefing)
email_recipients:
  - "your-email@example.com"

# File naming pattern
file_naming: "Atlas-Briefing-{yyyy}.{mm}.{dd}"

# Paper recommendations
num_paper_picks: 3

# Date range for arxiv search (days)
arxiv_days_back: 3

# Maximum items per section
max_papers: 30
max_blogs: 12
max_news: 15

# PDF settings
pdf:
  font_size: 10
  line_spacing: 1.5
  include_toc: true
  include_emoji: false

# Amazon Bedrock configuration
# Set enabled: false to run in deterministic mode (no LLM, zero cost)
bedrock:
  enabled: true
  region: "us-east-1"
  temperature: 0.3
  max_tokens: 2048
  # Use cross-region inference profile IDs (us.*) for broad region support.
  # On-demand IDs (e.g. amazon.nova-lite-v1:0) may not work in all regions.
  models:
    heavy: "us.anthropic.claude-sonnet-4-20250514-v1:0"
    medium: "us.amazon.nova-pro-v1:0"
    light: "us.amazon.nova-lite-v1:0"
  # Maximum LLM calls per run (default: 20). The intelligence layer makes
  # ~10-15 calls with default settings. Increase if you have many papers or
  # enable all intelligence features.
  max_calls_per_run: 25

# Logging
log_level: "INFO"

# Tracked entities for competitive intelligence
tracked_entities:
  - name: "OpenAI"
    type: "company"
  - name: "Anthropic"
    type: "company"
  - name: "Google DeepMind"
    type: "company"
